rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Golden Model: Isolate all user-owned data in subcollections
    match /users/{userId} {
      allow read: if request.auth != null; // Optionally restrict to self or admins if user profiles are private
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == "SUPERADMIN" || request.auth.token.role == "ADMIN");
      
      // Allow the user full access to their own subcollections
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == "SUPERADMIN" || request.auth.token.role == "ADMIN");
      }
    }

    // Protect global collections from unauthorized reads/writes
    match /contacts/{document=**} {
      allow read, write: if request.auth != null && (request.auth.token.role == "SUPERADMIN" || request.auth.token.role == "ADMIN");
    }
    
    // Default fallback - deny everything else
    match /{document=**} {
      allow read, write: if request.auth != null && (request.auth.token.role == "SUPERADMIN" || request.auth.token.role == "ADMIN");
    }
  }
}
